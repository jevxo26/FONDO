  events    TrackingEvent[]
  eta       TrackingETA?

  @@map("tracking_sessions")
}

model TrackingLocation {
  id                String   @id @default(uuid())
  trackingSessionId String
  latitude          Float
  longitude         Float
  speed             Float?
  heading           Float?
  accuracy          Float?
  recordedAt        DateTime @default(now())

  trackingSession TrackingSession @relation(fields: [trackingSessionId], references: [id])

  @@map("tracking_locations")
}

model TrackingEvent {
  id                String   @id @default(uuid())
  trackingSessionId String
  event             String
  description       String?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime @default(now())

  trackingSession TrackingSession @relation(fields: [trackingSessionId], references: [id])

  @@map("tracking_events")
}

model TrackingETA {
  id                   String   @id @default(uuid())
  trackingSessionId    String   @unique
  estimatedArrivalTime DateTime?
  remainingDistance    Float?
  remainingDuration    Int?
  trafficStatus        String?
  updatedAt            DateTime @updatedAt

  trackingSession TrackingSession @relation(fields: [trackingSessionId], references: [id])

  @@map("tracking_etas")
}

model Route {
  id              String   @id @default(uuid())
  routeCode       String   @unique
  vendorId        String?
  riderId         String?
  routeName       String?
  totalDistance   Float?
  estimatedDuration Int?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor       Vendor?                 @relation(fields: [vendorId], references: [id])
  stops        RouteStop[]
  optimization RouteOptimization?
  trackings    RouteTracking[]
  histories    RouteHistory[]

  @@map("routes")
}

model RouteStop {
  id            String    @id @default(uuid())
  routeId       String
  deliveryId    String?
  customerId    String?
  addressId     String?
  stopNumber    Int
  arrivalTime   DateTime?
  departureTime DateTime?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  route Route @relation(fields: [routeId], references: [id])

  @@map("route_stops")
}

model RouteOptimization {
  id               String   @id @default(uuid())
  routeId          String   @unique
  algorithm        String?
  optimizationScore Float?
  totalDistance    Float?
  totalTime        Int?
  fuelSaving       Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  route Route @relation(fields: [routeId], references: [id])

  @@map("route_optimizations")
}

model RouteTracking {
  id               String   @id @default(uuid())
  routeId          String   @unique
  currentLatitude  Float?
  currentLongitude Float?
  currentStop      Int?
  remainingDistance Float?
  remainingTime    Int?
  updatedAt        DateTime @updatedAt

  route Route @relation(fields: [routeId], references: [id])

  @@map("route_trackings")
}

model RouteHistory {
  id        String   @id @default(uuid())
  routeId   String
  oldRoute  String?
  newRoute  String?
  changedBy String?
  reason    String?
  createdAt DateTime @default(now())

  route Route @relation(fields: [routeId], references: [id])

  @@map("route_histories")
}

// ============================================================
// MODULE 10: CHAT, NOTIFICATION & SUPPORT
// ============================================================

model Conversation {
  id               String   @id @default(uuid())
  conversationCode String?
  conversationType ConversationType
  title            String?
  createdBy        String?
  status           String   @default("active")
  lastMessageId    String?
  lastMessageAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  userType       String
  role           String?
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  isMuted        Boolean  @default(false)
  isBlocked      Boolean  @default(false)
  lastSeenMessageId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("conversation_participants")
}

model Message {
  id              String    @id @default(uuid())
  conversationId  String
  senderId        String
  senderType      String?
  messageType     MessageType
  message         String?
  replyMessageId  String?
  forwardMessageId String?
  status          String    @default("sent")
  sentAt          DateTime  @default(now())
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversation Conversation      @relation(fields: [conversationId], references: [id])
  attachments  MessageAttachment[]
  reactions    MessageReaction[]
  reads        MessageRead[]
  deletes      MessageDelete[]

  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileName  String
  fileType  String?
  fileUrl   String
  fileSize  Int?
  thumbnail String?
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id])

  @@map("message_attachments")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  reaction  String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])

  @@map("message_reactions")
}

model MessageRead {
  id        String    @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime  @default(now())

  message Message @relation(fields: [messageId], references: [id])

  @@map("message_reads")
}

model MessageDelete {
  id         String   @id @default(uuid())
  messageId  String
  deletedBy  String
  deleteType String
  deletedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])

  @@map("message_deletes")
}

model SupportTicket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique
  customerId   String
  orderId      String?
  categoryId   String?
  subject      String
  description  String
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus @default(OPEN)
  assignedTo   String?
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer User           @relation(fields: [customerId], references: [id])
  category SupportCategory? @relation(fields: [categoryId], references: [id])
  replies  SupportReply[]

  @@map("support_tickets")
}

model SupportCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets SupportTicket[]

  @@map("support_categories")
}

model SupportReply {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  message    String
  attachment String?
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
  user   User          @relation(fields: [userId], references: [id])

  @@map("support_replies")
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  title         String
  message       String
  type          String?
  referenceType String?
  referenceId   String?
  isRead        Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ============================================================
// MODULE 11: CMS, ANALYTICS, SYSTEM SETTINGS
// ============================================================

model Banner {
  id           String    @id @default(uuid())
  title        String
  subtitle     String?
  image        String
  redirectType String?
  redirectId   String?
  displayOrder Int       @default(0)
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("banners")
}

model Slider {
  id           String   @id @default(uuid())
  title        String
  description  String?
  image        String
  buttonText   String?
  buttonUrl    String?
  displayOrder Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sliders")
}

model Blog {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  thumbnail   String?
  content     String
  authorId    String?
  categoryId  String?
  status      String    @default("draft")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category BlogCategory? @relation(fields: [categoryId], references: [id])

  @@map("blogs")
}

model BlogCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blogs Blog[]

  @@map("blog_categories")
}

model StaticPage {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  content        String
  metaTitle      String?
  metaDescription String?
  status         String   @default("published")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("static_pages")
}

model SystemSetting {
  id           String   @id @default(uuid())
  settingKey   String   @unique
  settingValue String
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("system_settings")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  featureName String
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  module    String
  action    String
  description String?
  ipAddress String?
  device    String?
  browser   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ============================================================
// MODULE 12: SUBSCRIPTION
// ============================================================

model Subscription {
  id                 String   @id @default(uuid())
  subscriptionNumber String   @unique
  customerId         String
  packageId          String?
  customMealPlanId   String?
  orderId            String?
  startDate          DateTime
  endDate            DateTime
  duration           Int
  status             SubscriptionStatus @default(PENDING)
  autoRenew          Boolean  @default(false)
  totalAmount        Decimal  @default(0) @db.Decimal(10, 2)
  paidAmount         Decimal  @default(0) @db.Decimal(10, 2)
  remainingAmount    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer User    @relation(fields: [customerId], references: [id])
  order    Order?  @relation(fields: [orderId], references: [id])

  @@map("subscriptions")
}

// ============================================================
// MODULE 13: COUPON, REFERRAL, LOYALTY
// ============================================================

model Coupon {
  id               String    @id @default(uuid())
  couponCode       String    @unique
  title            String?
  description      String?
  discountType     DiscountType
  discountValue    Decimal   @db.Decimal(10, 2)
  minimumOrderAmount Decimal? @db.Decimal(10, 2)
  maximumDiscount  Decimal?  @db.Decimal(10, 2)
  usageLimit       Int?
  perUserLimit     Int       @default(1)
  startDate        DateTime?
  endDate          DateTime?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id             String    @id @default(uuid())
  couponId       String
  customerId     String
  orderId        String?
  discountAmount Decimal?  @db.Decimal(10, 2)
  usedAt         DateTime  @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@map("coupon_usages")
}

model Referral {
  id            String   @id @default(uuid())
  referrerId    String   @unique
  referredUserId String  @unique
  referralCode  String   @unique
  rewardAmount  Decimal? @db.Decimal(10, 2)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referrer User @relation(fields: [referrerId], references: [id])

  @@map("referrals")
}

// ============================================================
// MODULE 14: INVENTORY
// ============================================================

model Inventory {
  id             String   @id @default(uuid())
  vendorId       String
  ingredientName String
  category       String?
  unit           String
  minimumStock   Float    @default(0)
  currentStock   Float    @default(0)
  maximumStock   Float?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor       Vendor                @relation(fields: [vendorId], references: [id])
  transactions InventoryTransaction[]
  wasteLogs    WasteLog[]

  @@map("inventories")
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  inventoryId     String
  transactionType String
  quantity        Float
  remainingQuantity Float?
  referenceType   String?
  referenceId     String?
  remarks         String?
  createdAt       DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@map("inventory_transactions")
}

model Supplier {
  id            String   @id @default(uuid())
  vendorId      String
  companyName   String
  contactPerson String?
  phone         String
  email         String?
  address       String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor   Vendor    @relation(fields: [vendorId], references: [id])
  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id             String    @id @default(uuid())
  supplierId     String
  vendorId       String
  purchaseNumber String    @unique
  purchaseDate   DateTime  @default(now())
  subtotal       Decimal?  @db.Decimal(10, 2)
  vat            Decimal?  @db.Decimal(10, 2)
  discount       Decimal?  @db.Decimal(10, 2)
  grandTotal     Decimal?  @db.Decimal(10, 2)
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier Supplier      @relation(fields: [supplierId], references: [id])
  vendor   Vendor        @relation(fields: [vendorId], references: [id])
  items    PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  inventoryId String
  quantity    Float
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@map("purchase_items")
}

model WasteLog {
  id          String   @id @default(uuid())
  inventoryId String
  quantity    Float
  reason      String
  approvedBy  String?
  createdAt   DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@map("waste_logs")
}
