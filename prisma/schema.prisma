generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  VENDOR
  VENDOR_STAFF
  KITCHEN_STAFF
  RIDER
  CUSTOMER
  SUPPORT_AGENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  UNDER_REVIEW
  VERIFIED
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

enum FoodType {
  VEG
  NON_VEG
  VEGAN
  SEAFOOD
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACKS
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  PICKED_UP
  ON_THE_WAY
  ARRIVED
  DELIVERED
  FAILED
  CANCELLED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  FROZEN
  COMPLETED
  EXPIRED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum ProofType {
  PHOTO
  SIGNATURE
  OTP
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum ConversationType {
  DIRECT
  GROUP
  SUPPORT
  ORDER
  DELIVERY
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  ORDER
  PAYMENT
  SYSTEM
}

// ============================================================
// MODULE 1: AUTHENTICATION
// ============================================================

model User {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  phone           String    @unique
  email           String    @unique
  password        String?
  avatar          String?
  gender          Gender?
  dateOfBirth     DateTime?
  role            Role      @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  profile            UserProfile?
  addresses          UserAddress[]
  devices            UserDevice[]
  sessions           UserSession[]
  otps               UserOTP[]
  tokens             UserToken[]
  loginHistory       UserLoginHistory[]
  security           UserSecurity?
  notificationSetting UserNotificationSetting?
  userRoles          UserRole[]
  favorites          FoodFavorite[]
  foodReviews        FoodReview[]
  cart               Cart?
  orders             Order[]
  payments           Payment[]
  wallet             CustomerWallet?
  subscriptions      Subscription[]
  customMealPlans    CustomMealPlan[]
  mealPreferences    MealPreference[]
  dietaryRestrictions DietaryRestriction[]
  supportTickets     SupportTicket[]
  supportReplies     SupportReply[]
  notifications      Notification[]
  activityLogs       ActivityLog[]
  referral           Referral?

  @@map("users")
}

model UserProfile {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  profession                String?
  occupation                String?
  company                   String?
  bio                       String?
  preferredLanguage         String?
  timezone                  String?
  profileCompletionPercentage Float?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model UserAddress {
  id                String   @id @default(uuid())
  userId            String
  label             String?
  receiverName      String
  receiverPhone     String
  country           String?
  division          String
  district          String
  upazila           String?
  area              String
  road              String?
  house             String?
  floor             String?
  apartment         String?
  landmark          String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  deliveryInstruction String?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("user_addresses")
}

model UserDevice {
  id              String   @id @default(uuid())
  userId          String
  deviceId        String
  deviceName      String?
  deviceType      String
  operatingSystem String?
  osVersion       String?
  appVersion      String?
  browser         String?
  pushToken       String
  ipAddress       String?
  lastActiveAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_devices")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String?
  accessToken  String
  refreshToken String
  ipAddress    String?
  loginAt      DateTime?
  expiresAt    DateTime
  logoutAt     DateTime?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model UserOTP {
  id          String    @id @default(uuid())
  userId      String?
  phone       String?
  email       String?
  otp         String
  purpose     String
  expiresAt   DateTime
  verifiedAt  DateTime?
  attemptCount Int      @default(0)
  status      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@map("user_otps")
}

model UserToken {
  id        String    @id @default(uuid())
  userId    String
  token     String
  type      String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_tokens")
}

model UserLoginHistory {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String?
  ipAddress   String?
  browser     String?
  platform    String?
  country     String?
  city        String?
  loginMethod String?
  loginStatus String?
  loggedInAt  DateTime?
  loggedOutAt DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("user_login_histories")
}

model UserSecurity {
  id                  String    @id @default(uuid())
  userId              String    @unique
  passwordChangedAt   DateTime?
  failedLoginCount    Int       @default(0)
  lastFailedLoginAt   DateTime?
  twoFactorEnabled    Boolean   @default(false)
  accountLocked       Boolean   @default(false)
  accountLockedUntil  DateTime?
  securityQuestion    String?
  securityAnswer      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_securities")
}

model UserNotificationSetting {
  id                  String  @id @default(uuid())
  userId              String  @unique
  pushNotification    Boolean @default(true)
  emailNotification   Boolean @default(true)
  smsNotification     Boolean @default(false)
  orderNotification   Boolean @default(true)
  paymentNotification Boolean @default(true)
  promotionNotification Boolean @default(false)
  chatNotification    Boolean @default(true)
  marketingNotification Boolean @default(false)
  systemNotification  Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_notification_settings")
}

// ============================================================
// MODULE 2: ROLE & PERMISSION
// ============================================================

model RbacRole {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("rbac_roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       RbacRole   @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@map("role_permissions")
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime  @default(now())
  expiresAt  DateTime?
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User     @relation(fields: [userId], references: [id])
  role RbacRole @relation(fields: [roleId], references: [id])

  @@map("user_roles")
}

// ============================================================
// MODULE 3: VENDOR
// ============================================================

model Vendor {
  id                 String           @id @default(uuid())
  vendorCode         String           @unique
  businessName       String
  ownerName          String
  phone              String           @unique
  email              String           @unique
  tradeLicenseNumber String           @unique
  tinNumber          String           @unique
  binNumber          String           @unique
  logo               String?
  coverImage         String?
  description        String?
  status             VendorStatus     @default(PENDING)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isActive           Boolean          @default(true)
  isOnline           Boolean          @default(false)
  commissionType     CommissionType   @default(PERCENTAGE)
  commissionValue    Decimal          @default(0.00) @db.Decimal(10, 2)
  openingTime        String?
  closingTime        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  profile             VendorProfile?
  branches            VendorBranch[]
  kitchens            VendorKitchen[]
  staff               VendorStaff[]
  documents           VendorDocument[]
  bankAccounts        VendorBankAccount[]
  paymentInfos        VendorPaymentInfo[]
  operatingHours      VendorOperatingHour[]
  holidays            VendorHoliday[]
  serviceAreas        VendorServiceArea[]
  zones               VendorZone[]
  subscriptions       VendorSubscription[]
  commissions         VendorCommission[]
  settlements         VendorSettlement[]
  wallet              VendorWallet?
  rating              VendorRating?
  reviews             VendorReview[]
  notifications       VendorNotification[]
  settings            VendorSettings?
  activityLogs        VendorActivityLog[]
  earnings            VendorEarning[]
  vendorFoods         VendorFood[]
  vendorFoodAssignments VendorFoodAssignment[]
  riders              Rider[]
  deliveries          Delivery[]
  routes              Route[]
  inventories         Inventory[]
  suppliers           Supplier[]
  purchases           Purchase[]
  orders              Order[]

  @@map("vendors")
}

model VendorProfile {
  id              String   @id @default(uuid())
  vendorId        String   @unique
  businessType    String?
  businessCategory String?
  foundedYear     Int?
  employeeCount   Int?
  website         String?
  facebook        String?
  instagram       String?
  youtube         String?
  description     String?
  mission         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_profiles")
}

model VendorBranch {
  id          String   @id @default(uuid())
  vendorId    String
  branchName  String
  branchCode  String   @unique
  phone       String?
  email       String?
  country     String?
  division    String?
  district    String?
  upazila     String?
  area        String?
  road        String?
  house       String?
  postalCode  String?
  latitude    Float?
  longitude   Float?
  isMainBranch Boolean @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor  Vendor         @relation(fields: [vendorId], references: [id])
  kitchens VendorKitchen[]
  staff    VendorStaff[]

  @@map("vendor_branches")
}

model VendorKitchen {
  id              String   @id @default(uuid())
  vendorId        String
  branchId        String?
  kitchenName     String
  kitchenCode     String   @unique
  capacity        Int?
  preparationTime Int?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor Vendor       @relation(fields: [vendorId], references: [id])
  branch VendorBranch? @relation(fields: [branchId], references: [id])

  @@map("vendor_kitchens")
}

model VendorStaff {
  id          String   @id @default(uuid())
  vendorId    String
  branchId    String?
  userId      String?
  fullName    String
  phone       String
  email       String?
  designation String
  joiningDate DateTime?
  salary      Decimal? @db.Decimal(10, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor      Vendor        @relation(fields: [vendorId], references: [id])
  branch      VendorBranch?  @relation(fields: [branchId], references: [id])

  @@map("vendor_staff")
}

model VendorDocument {
  id                 String    @id @default(uuid())
  vendorId           String
  documentType       String
  documentNumber     String?
  documentFile       String
  issueDate          DateTime?
  expiryDate         DateTime?
  verificationStatus String    @default("pending")
  verifiedBy         String?
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_documents")
}

model VendorBankAccount {
  id                 String   @id @default(uuid())
  vendorId           String
  bankName           String
  branchName         String?
  accountName        String
  accountNumber      String
  routingNumber      String?
  mobileBankingType  String?
  mobileBankingNumber String?
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_bank_accounts")
}

model VendorPaymentInfo {
  id            String   @id @default(uuid())
  vendorId      String
  paymentMethod String
  accountName   String?
  accountNumber String?
  walletNumber  String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_payment_infos")
}

model VendorOperatingHour {
  id          String   @id @default(uuid())
  vendorId    String
  day         String
  openingTime String
  closingTime String
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_operating_hours")
}

model VendorHoliday {
  id          String   @id @default(uuid())
  vendorId    String
  holidayName String
  holidayDate DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_holidays")
}

model VendorServiceArea {
  id                  String   @id @default(uuid())
  vendorId            String
  division            String
  district            String
  upazila             String?
  area                String
  deliveryCharge      Decimal? @db.Decimal(10, 2)
  minimumOrderAmount  Decimal? @db.Decimal(10, 2)
  estimatedDeliveryTime Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_service_areas")
}

model VendorZone {
  id          String   @id @default(uuid())
  vendorId    String
  zoneName    String
  zoneCode    String?  @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_zones")
}

model VendorSubscription {
  id            String    @id @default(uuid())
  vendorId      String
  planId        String?
  startDate     DateTime
  endDate       DateTime
  amount        Decimal   @db.Decimal(10, 2)
  paymentStatus String    @default("pending")
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_subscriptions")
}

model VendorCommission {
  id                 String   @id @default(uuid())
  vendorId           String
  commissionType     String?
  commissionPercentage Decimal? @db.Decimal(5, 2)
  flatAmount         Decimal? @db.Decimal(10, 2)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_commissions")
}

model VendorSettlement {
  id                  String   @id @default(uuid())
  vendorId            String
  settlementNumber    String   @unique
  settlementPeriodStart DateTime?
  settlementPeriodEnd   DateTime?
  totalOrders         Int?
  grossAmount         Decimal? @db.Decimal(10, 2)
  totalCommission     Decimal? @db.Decimal(10, 2)
  vatAmount           Decimal? @db.Decimal(10, 2)
  adjustmentAmount    Decimal? @db.Decimal(10, 2)
  totalPayable        Decimal? @db.Decimal(10, 2)
  netAmount           Decimal? @db.Decimal(10, 2)
  settlementDate      DateTime?
  paymentStatus       String   @default("pending")
  transactionId       String?
  paymentDate         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor       Vendor                   @relation(fields: [vendorId], references: [id])
  items        VendorSettlementItem[]
  transactions VendorSettlementTransaction[]

  @@map("vendor_settlements")
}

model VendorSettlementItem {
  id             String   @id @default(uuid())
  settlementId   String
  orderId        String
  orderAmount    Decimal  @db.Decimal(10, 2)
  commission     Decimal? @db.Decimal(10, 2)
  adjustment     Decimal? @db.Decimal(10, 2)
  payableAmount  Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  settlement VendorSettlement @relation(fields: [settlementId], references: [id])

  @@map("vendor_settlement_items")
}

model VendorSettlementTransaction {
  id            String   @id @default(uuid())
  settlementId  String
  transactionId String?
  bankAccountId String?
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String?
  status        String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  settlement VendorSettlement @relation(fields: [settlementId], references: [id])

  @@map("vendor_settlement_transactions")
}

model VendorWallet {
  id          String   @id @default(uuid())
  vendorId    String   @unique
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  holdBalance Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("BDT")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor       Vendor                    @relation(fields: [vendorId], references: [id])
  transactions VendorWalletTransaction[]

  @@map("vendor_wallets")
}

model VendorWalletTransaction {
  id              String   @id @default(uuid())
  walletId        String
  transactionType String
  amount          Decimal  @db.Decimal(10, 2)
  balanceBefore   Decimal? @db.Decimal(10, 2)
  balanceAfter    Decimal? @db.Decimal(10, 2)
  referenceId     String?
  remarks         String?
  createdAt       DateTime @default(now())

  wallet VendorWallet @relation(fields: [walletId], references: [id])

  @@map("vendor_wallet_transactions")
}

model VendorRating {
  id          String @id @default(uuid())
  vendorId    String @unique
  averageRating Float? @default(0)
  totalRating    Int?   @default(0)
  fiveStar    Int?   @default(0)
  fourStar    Int?   @default(0)
  threeStar   Int?   @default(0)
  twoStar     Int?   @default(0)
  oneStar     Int?   @default(0)
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_ratings")
}

model VendorReview {
  id         String   @id @default(uuid())
  vendorId   String
  customerId String
  rating     Int
  review     String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_reviews")
}

model VendorNotification {
  id        String   @id @default(uuid())
  vendorId  String
  title     String
  message   String
  type      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_notifications")
}

model VendorSettings {
  id                String  @id @default(uuid())
  vendorId          String  @unique
  autoAcceptOrder   Boolean @default(false)
  autoAssignRider   Boolean @default(false)
  allowCustomMeal   Boolean @default(true)
  allowPackage      Boolean @default(true)
  notificationEnabled Boolean @default(true)
  smsEnabled        Boolean @default(false)
  emailEnabled      Boolean @default(false)
  status            String  @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_settings")
}

model VendorActivityLog {
  id        String   @id @default(uuid())
  vendorId  String
  staffId   String?
  activity  String
  module    String?
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_activity_logs")
}

model VendorEarning {
  id                String   @id @default(uuid())
  vendorId          String
  orderId           String
  grossAmount       Decimal? @db.Decimal(10, 2)
  commission        Decimal? @db.Decimal(10, 2)
  netAmount         Decimal? @db.Decimal(10, 2)
  settlementStatus  String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_earnings")
}

// ============================================================
// MODULE 4: FOOD CATALOG
// ============================================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  sortOrder   Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  subCategories SubCategory[]
  foods         Food[]

  @@map("categories")
}

model SubCategory {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  sortOrder   Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  category Category @relation(fields: [categoryId], references: [id])
  foods    Food[]

  @@map("sub_categories")
}

model Food {
  id               String   @id @default(uuid())
  categoryId       String
  subCategoryId    String?
  foodCode         String   @unique
  name             String
  slug             String   @unique
  shortDescription String?
  description      String?
  thumbnail        String?
  coverImage       String?
  preparationTime  Int?
  calories         Float?
  protein          Float?
  fat              Float?
  carbohydrate     Float?
  servingSize      String?
  foodType         FoodType
  spiceLevel       String?
  isFeatured       Boolean  @default(false)
  isPopular        Boolean  @default(false)
  isRecommended    Boolean  @default(false)
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

